{
    "name": "pdf-block/laravel",
    "description": "Server-side PDF renderer for pdf-block DSL documents. Converts JSON DSL to native PDF via Browsershot (Puppeteer).",
    "keywords": ["pdf", "laravel", "renderer", "dsl", "document", "puppeteer", "browsershot"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "spatie/browsershot": "^4.0",
        "ueberdosis/tiptap-php": "^1.6"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PdfBlock\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PdfBlock\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PdfBlock\\Laravel\\PdfBlockServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
