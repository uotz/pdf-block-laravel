{
  "name": "@pdf-block/react",
  "version": "1.0.2",
  "type": "module",
  "description": "A visual, drag-and-drop PDF document builder for React. Renders a full WYSIWYG editor with inline styles, ready for server-side PDF generation.",
  "keywords": [
    "pdf",
    "builder",
    "react",
    "editor",
    "wysiwyg",
    "drag-and-drop",
    "document"
  ],
  "license": "MIT",
  "author": "Jonathas Yoharu <jonathas_a.a@hotmail.com>",
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "dist/pdf-block.cjs.js",
  "module": "dist/pdf-block.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pdf-block.es.js",
      "require": "./dist/pdf-block.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:lib": "vite build --config vite.lib.config.ts && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build:lib",
    "release": "npm run build:lib && npm version ${VERSION:?Usage: VERSION=1.2.3 pnpm release} --no-git-tag-version && npm publish --access public"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-blockquote": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "immer": "^10.1.1",
    "lucide-react": "^1.8.0",
    "react-colorful": "^5.6.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  }
}
