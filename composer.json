{
    "name": "pdf-block/laravel",
    "description": "Server-side PDF renderer for pdf-block DSL documents. Converts JSON DSL to native PDF via a local Chromium binary or a remote Browserless (v2) service.",
    "keywords": ["pdf", "laravel", "renderer", "dsl", "document", "chromium", "browserless", "headless"],
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathas Yoharu",
            "homepage": "https://github.com/uotz"
        }
    ],
    "homepage": "https://github.com/uotz/pdf-block-laravel",
    "type": "library",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "symfony/process": "^6.0|^7.0",
        "ueberdosis/tiptap-php": "^1.0|^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PdfBlock\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PdfBlock\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PdfBlock\\Laravel\\PdfBlockServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
